{
  "build": {
    "beforeBuildCommand": "cd src-ui && npm run build",
    "beforeDevCommand": "cd src-ui && npm run dev",
    "devPath": "http://localhost:1420",
    "distDir": "../src-ui/dist"
  },
  "productName": "Desktop AI Agent",
  "version": "0.1.0",
  "identifier": "com.desktop-agent.app",
  "plugins": {},
  "app": {
    "security": {
      "csp": null
    },
    "windows": [
      {
        "title": "Desktop AI Agent",
        "width": 1200,
        "height": 800,
        "resizable": true,
        "fullscreen": false
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}